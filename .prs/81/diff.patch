+    """Determine the resolution base directory for workspace sync."""
+    if ws_cfg.resolution_base is not None:
+        return ws_cfg.resolution_base
+    if ws_cfg.workspace_file is not None:
+        return ws_cfg.workspace_file.parent
+    return project_root
