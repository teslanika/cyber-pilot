+# @cpt-begin:cpt-cypilot-algo-workspace-resolve-git-url:p1:inst-git-clone-or-fetch
+def _clone_if_missing(url: str, local_path: Path, branch: str) -> Optional[Path]:
+    """Clone a git repo or return existing local path.
