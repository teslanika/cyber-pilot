+    from cypilot.cli import main
+    from cypilot.utils.ui import is_json_mode, set_json_mode
+
+    cwd = os.getcwd()
+    saved_json_mode = is_json_mode()
+    try:
+        os.chdir(str(root))
+        stdout = io.StringIO()
+        with redirect_stdout(stdout):
+            exit_code = main(args)
+        out = json.loads(stdout.getvalue())
+        return exit_code, out
+    finally:
